{
  "appId": "com.girlfit.app",
  "appName": "GirlFit",
  "webDir": "www",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#FF6B9D",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#FF6B9D"
    }
  },
  "android": {
    "allowMixedContent": true,
    "backgroundColor": "#FFF5F8"
  }
}
